# SQLite 数据库路径
DB_PATH=data/rag.db

# 模型后端选择：local（本地 SentenceTransformer/CrossEncoder）或 ollama（Ollama API）
EMBED_BACKEND=ollama
RERANKER_BACKEND=ollama
LLM_BACKEND=ollama

# 本地模型目录（仅 local 后端使用）
LOCAL_MODEL_DIR=~/.cache/modelscope/hub/models/Qwen

# 嵌入模型（local 后端）
EMBED_MODEL_PATH=~/.cache/modelscope/hub/models/Qwen/Qwen3-Embedding-0___6B
VECTOR_DIMS=1024

# 精排模型（local 后端）
RERANKER_MODEL_PATH=~/.cache/modelscope/hub/models/Qwen/Qwen3-Reranker-0___6B
RERANKER_TOP_K=5

# 切片参数
CHUNK_SIZE=700
CHUNK_OVERLAP=100

# Ollama（ollama 后端）
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL_NAME=qwen2.5:3b
OLLAMA_EMBED_MODEL=bge-large:latest
OLLAMA_RERANKER_MODEL=qwen3-reranker-0.6b

# 数据文件
DATA_DIR=docs

# 检索参数
SEARCH_TOP_K=15
RECALL_TOP_K=50

# RRF 融合参数
RRF_RANK_CONSTANT=60
KNN_WEIGHT=0.6
BM25_WEIGHT=0.4
