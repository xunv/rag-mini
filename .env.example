# SQLite 数据库路径
DB_PATH=data/rag.db

# 嵌入模型（通过 Ollama embedding API）
EMBED_MODEL_NAME=bge-large:latest

# Ollama（LLM 生成 + 向量嵌入）
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL_NAME=qwen2.5:3b

# 数据文件
DATA_DIR=docs

# 切片参数
CHUNK_SIZE=600
CHUNK_OVERLAP=80

# 检索参数
SEARCH_TOP_K=15

# RRF 融合参数
RRF_RANK_CONSTANT=60
KNN_WEIGHT=0.25
BM25_WEIGHT=0.75

# 向量维度
VECTOR_DIMS=1024