# Elasticsearch
ES_URL=http://localhost:9200
ES_INDEX_NAME=hongloumeng_index

# 嵌入模型（通过 Ollama embedding API）
EMBED_MODEL_NAME=bge-large:latest

# Ollama（LLM 生成 + 向量嵌入）
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL_NAME=qwen2.5:3b

# 数据文件
DATA_DIR=docs
FILE_PATH=docs/hongloumeng.txt

# 切片参数
CHUNK_SIZE=800
CHUNK_OVERLAP=80

# 检索参数
SEARCH_TOP_K=5
SEARCH_NUM_CANDIDATES=200

# RRF 融合参数
RRF_RANK_CONSTANT=60
KNN_WEIGHT=0.7
BM25_WEIGHT=0.3

# 向量维度
VECTOR_DIMS=1024